# ANSEM Index Keeper — NEVER commit secrets
#
# Creator fee wallet structure (LIFE-style):
#   W0 MAIN_WALLET         — fund source (never signs)
#   W1 LP_WALLET           — owns Meteora positions, claims fees
#   W2 OPERATOR_WALLET     — Jupiter buy + SPL send signer
#   ANSEM_DEST_WALLET      — receives bought ANSEM (replaces LIFE burn)

CELL_ID=ansem-index
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
ANSEM_MINT=9cRCn9rGT8V2imeM2BaKs13yhMEais3ruM3rPvTGpump

MAIN_WALLET=
LP_WALLET=HpJbzERP44V21mKGRDDUArb9JJaL9NdPSgXzZ9uyieVB
OPERATOR_WALLET=
ANSEM_DEST_WALLET=

# Secrets — put in cell_secrets.env (chmod 600) or Railway secrets
# LP_PRIVATE_KEY=
# OPERATOR_PRIVATE_KEY=

# Fee split (must sum to 1.0) — 70% buy+send ANSEM, 30% reserve
FEE_SPLIT_ANSEM_SEND=0.7
FEE_SPLIT_RESERVE=0.3
FEE_SPLIT_REINVEST=0

# Optional fixed $ cap on ANSEM send per tick (0 = use pct)
ANSEM_SEND_CAP_USD=0

MIN_CLAIM_USD=1
MIN_ROUTE_USD=1
MIN_RESERVE_USD=5
MAX_BUY_USD_PER_RUN=50
MAX_CLAIM_PER_TICK=20
SLIPPAGE_BPS=250
TICK_MS=60000
LP_RESERVE_SOL=0.01

# Safety — keep true until go-live
DRY_RUN=true
SIMULATION_MODE=true
MANUAL=false

HEALTH_ENABLED=true
HEALTH_PORT=8080
