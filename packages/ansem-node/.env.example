# ANSEM node — NEVER commit secrets
#
# Join flow:
#   1. Buy $ANSEMLP (when live) — creator fees → buybacks + growth
#   2. Deposit independently into Index pools on app.meteora.ag
#   3. Pull the list: pnpm index
#   4. Run this node locally or on Railway
#
# Wallets (LIFE-style):
#   W0 MAIN_WALLET         — fund source (never signs)
#   W1 LP_WALLET           — owns Meteora positions, claims fees
#   W2 OPERATOR_WALLET     — Jupiter buy + SPL send signer
#   ANSEM_DEST_WALLET      — receives bought ANSEM

CELL_ID=my-ansem-node
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
ANSEM_MINT=9cRCn9rGT8V2imeM2BaKs13yhMEais3ruM3rPvTGpump

# Key market: $ANSEMLP–ANSEM (set when live)
# INDEX_TOKEN_MINT=
# INDEX_POOL_ADDRESS=

# Public hub — pull the index (no keys)
INDEX_API_URL=https://hub-production-7867.up.railway.app/api/public
HUB_URL=https://hub-production-7867.up.railway.app

# Influence leader (Mike) — optional reference only
INFLUENCE_LEADER_LP=HpJbzERP44V21mKGRDDUArb9JJaL9NdPSgXzZ9uyieVB

MAIN_WALLET=
LP_WALLET=
OPERATOR_WALLET=
ANSEM_DEST_WALLET=

# Secrets — put in cell_secrets.env (chmod 600) or Railway secrets
# LP_PRIVATE_KEY=
# OPERATOR_PRIVATE_KEY=

FEE_SPLIT_ANSEM_SEND=0.7
FEE_SPLIT_RESERVE=0.3
FEE_SPLIT_REINVEST=0

ANSEM_SEND_CAP_USD=0
MIN_CLAIM_USD=1
MIN_ROUTE_USD=1
MIN_RESERVE_USD=5
MAX_BUY_USD_PER_RUN=50
MAX_CLAIM_PER_TICK=20
SLIPPAGE_BPS=250
TICK_MS=60000
LP_RESERVE_SOL=0.01

# Safety — keep true until go-live
DRY_RUN=true
SIMULATION_MODE=true
MANUAL=false

HEALTH_ENABLED=true
HEALTH_PORT=8080
